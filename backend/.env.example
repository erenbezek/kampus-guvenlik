PORT=3001
MONGODB_URI=mongodb://localhost:27017/campus_safety
JWT_SECRET=degistir-bunu-guclu-bir-sifre-yaz
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Demo için BTU- cihazlarına sahte sensör verisi üretir (true/false)
ENABLE_FAKE_SENSORS=true

# ISP'nin MongoDB Atlas SRV sorgularını bloklaması durumunda Google DNS kullan
USE_CUSTOM_DNS=false

# Render free tier'da uygulamayı uykuya geçmekten korumak için 10 dakikada
# bir kendi health endpoint'ine istek atar. Render'daki servis URL'in ile doldur.
# SELF_PING_URL=https://<render-app-adi>.onrender.com/api/health
